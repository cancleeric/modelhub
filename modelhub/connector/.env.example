# ModelHub Connector 環境變數範本
# 複製為 .env 並填入實際值（從 Hurricane Vault 取得）

# brain-cloud WebSocket endpoint
BRAIN_CLOUD_WS_URL=ws://localhost:8932/ws/llm-provider

# brain-cloud provider 認證金鑰
# Vault key: hurricanecore/dev/BRAIN_PROVIDER_API_KEY
BRAIN_PROVIDER_API_KEY=

# ModelHub backend endpoint
MODELHUB_API_URL=http://localhost:8950

# ModelHub API key（對應 X-Api-Key header）
# Vault key: hurricanecore/dev/MODELHUB_API_KEY
MODELHUB_API_KEY=

# Connector 在 brain-cloud 的 provider identity
PROVIDER_ID=modelhub-connector

# fallback model slugs（當 /v1/models 查詢失敗時使用）
MODEL_SLUGS=modelhub/mh-2026-010,modelhub/mh-2026-011

# 推論請求超時（秒）
LLM_REQUEST_TIMEOUT=60

# log 輸出檔案（選填，不設則只輸出 stdout）
# CONNECTOR_LOG_FILE=/path/to/modelhub-connector.log
